{
  "name": "figma-tokens-action",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --outfile=dist/index.js",
    "tsc": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.0",
    "@figma/rest-api-spec": "^0.36.0",
    "style-dictionary": "^5.2.0"
  },
  "devDependencies": {
    "@bonniernews/eslint-config": "^2.0.2",
    "@bonniernews/tsconfig": "^0.0.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.19.0",
    "typescript": "^5.6.0"
  }
}
