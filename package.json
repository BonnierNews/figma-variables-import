{
  "name": "@bonniernews/figma-variables-import",
  "version": "2.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "default": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist/lib/",
    "dist/index.js",
    "action.yml"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "npm run build:action && npm run build:package",
    "build:action": "esbuild src/main.ts --bundle --platform=node --format=esm --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --outfile=dist/index.js",
    "build:package": "esbuild src/index.ts --bundle --platform=node --format=esm --external:@figma/rest-api-spec --external:style-dictionary --outfile=dist/lib/index.js && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build:package",
    "tsc": "tsc --noEmit",
    "lint": "eslint .",
    "example": "node --env-file=example/.env example/run.ts"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@figma/rest-api-spec": "^0.36.0",
    "style-dictionary": "^5.2.0"
  },
  "devDependencies": {
    "@bonniernews/eslint-config": "^2.0.2",
    "@bonniernews/tsconfig": "^0.0.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.19.0",
    "typescript": "^5.6.0"
  }
}
